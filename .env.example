# ==============================================================================
# DISGRAM CONFIGURATION TEMPLATE (.env)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Discord Webhook Settings
# ------------------------------------------------------------------------------
# DISCORD_WEBHOOK_URL: The URL of your Discord webhook channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/{webhookID}/{webhookToken}

# DISCORD_THREAD_ID (Optional): ID of a specific Discord thread to forward messages into
DISCORD_THREAD_ID=1234567890987654321

# EMBED_COLOR: Hex color for the Discord message container accent borders (default: random color)
EMBED_COLOR=89a7d9

# API_BEARER_TOKEN: Bearer Token required to authorize administrative endpoints (POST /force-commit, POST /logs/clear)
API_BEARER_TOKEN=secret_admin_token

# ------------------------------------------------------------------------------
# 2. Telegram Channels Settings
# ------------------------------------------------------------------------------
# Comma-separated list of Telegram channels to scrape.
# - Channel format: https://t.me/channelname (starts scraping from the beginning)
# - Message format: https://t.me/channelname/123 (starts scraping from message #123)
TELEGRAM_CHANNELS=https://t.me/randomchannel,https://t.me/anotherchannel/322,https://t.me/yetanotherchannel/3456

# ------------------------------------------------------------------------------
# 3. Git Persistence Settings (Optional)
# ------------------------------------------------------------------------------
# USE_GIT: Set to false to completely disable all Git initialization, commits, and pushes.
# Ideal for simple self-hosting setups where log tracking is not needed.
USE_GIT=true

# ==============================================================================
# DEMONSTRATION SCENARIO: GitHub App Auth with 4-Hour Custom Schedule
# The settings below show a configured Git persistence setup using a GitHub App.
# Replace these values with your own App IDs, keys, and repository URL.
# ==============================================================================

# --- AUTHENTICATION OPTIONS ---

# Option A: GitHub App Authentication (Preferred)
# GITHUB_APP_ID=123456
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_APP_INSTALLATION_ID=12345678

# Local path to your App's private key (.pem file)
GITHUB_APP_PRIVATE_KEY_PATH=disgram-bot.private-key.pem

# OR provide the raw multiline private key PEM directly (useful for Azure/cloud platforms)
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Option B: Personal Access Token (PAT)
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- REPOSITORY & SCHEDULING CONFIGURATION ---

# GITHUB_REPO_URL: Target clone/push repository (Format: https://github.com/username/repo.git)
GITHUB_REPO_URL=https://github.com/username/repository-name.git

# GITHUB_DEPLOY_BRANCH: The target branch to push logs to (default: prod)
GITHUB_DEPLOY_BRANCH=prod

# COMMIT_MODE: The log-persistence trigger mode
# Options: "interval" (commits every X seconds) or "scheduled" (at specific UTC hours)
COMMIT_MODE=scheduled

# --- INTERVAL MODE SETTINGS ---
# LOG_COMMIT_INTERVAL: Time in seconds between commits (used if COMMIT_MODE=interval)
# LOG_COMMIT_INTERVAL=3600

# --- SCHEDULED MODE SETTINGS ---
# COMMIT_SCHEDULE: Commit frequency
# Options: "hourly" (every hour), "every_2h" (every 2 hours), "custom" (specific hours)
COMMIT_SCHEDULE=custom

# COMMIT_CUSTOM_HOURS: Comma-separated UTC hours (0-23) for committing (used if COMMIT_SCHEDULE=custom)
# The configuration below triggers commits every 4 hours (12am, 4am, 8am, 12pm, 4pm, 8pm UTC)
COMMIT_CUSTOM_HOURS=0,4,8,12,16,20

# STARTUP_GRACE_PERIOD: Cooldown in seconds on boot before first auto-commit (default: 10 mins)
# Helps prevent infinite deployment loop restarts triggered by immediate commit pushes
STARTUP_GRACE_PERIOD=600

# ==============================================================================
# TELETHON / MTPROTO CONFIGURATION (For high-quality media scraping)
# ==============================================================================

# Get these from https://my.telegram.org/apps
TG_API_ID=api_id
TG_API_HASH=api_hash

# The session string generated by running generate_session.py
TG_SESSION_STRING=string_session